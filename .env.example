# ============================================================================
# AumOS Energy Sustainability — environment variable reference
# Copy to .env for local development. Never commit .env to source control.
# All variables use the AUMOS_ENERGY_ prefix.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (from aumos-common AumOSSettings)
# ---------------------------------------------------------------------------
AUMOS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aumos_energy

# ---------------------------------------------------------------------------
# Kafka (from aumos-common AumOSSettings)
# ---------------------------------------------------------------------------
AUMOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_KAFKA_CONSUMER_GROUP=aumos-energy-sustainability

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------
AUMOS_ENERGY_SERVICE_NAME=aumos-energy-sustainability

# ---------------------------------------------------------------------------
# Carbon intensity API (Electricity Maps)
# Leave CARBON_API_KEY empty to run in mock mode (development/testing)
# ---------------------------------------------------------------------------
AUMOS_ENERGY_CARBON_API_URL=https://api.electricitymap.org/v3
AUMOS_ENERGY_CARBON_API_KEY=
AUMOS_ENERGY_CARBON_API_TIMEOUT=10.0
AUMOS_ENERGY_CARBON_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Energy routing
# ---------------------------------------------------------------------------
AUMOS_ENERGY_DEFAULT_CARBON_THRESHOLD_GCO2_PER_KWH=150.0
AUMOS_ENERGY_RENEWABLE_PREFERENCE_WEIGHT=0.7
AUMOS_ENERGY_LATENCY_PREFERENCE_WEIGHT=0.3
AUMOS_ENERGY_ROUTING_CACHE_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# ESG reporting
# ---------------------------------------------------------------------------
AUMOS_ENERGY_ESG_REPORT_RETENTION_DAYS=2555
AUMOS_ENERGY_DEFAULT_REPORTING_PERIOD_DAYS=90

# ---------------------------------------------------------------------------
# Optimization advisor
# ---------------------------------------------------------------------------
AUMOS_ENERGY_OPTIMIZATION_REFRESH_HOURS=24
AUMOS_ENERGY_MIN_SAVINGS_THRESHOLD_KG_CO2=1.0

# ---------------------------------------------------------------------------
# Redis (caching)
# ---------------------------------------------------------------------------
AUMOS_ENERGY_REDIS_URL=redis://localhost:6379/0
